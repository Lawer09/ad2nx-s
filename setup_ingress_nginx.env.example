# Required upstreams
export USER_REPORT_UPSTREAM="10.0.0.11:8081"
export NODE_REPORT_UPSTREAM="10.0.0.12:8082"
export DISPATCH_UPSTREAM="10.0.0.13:8083"

# Optional routing prefixes
export USER_REPORT_PREFIX="/user"
export NODE_REPORT_PREFIX="/node"
export DISPATCH_PREFIX="/dispatch"

# Nginx basics
export NGINX_LISTEN_PORT="80"
export NGINX_HTTPS_PORT="443"
export NGINX_SERVER_NAME="api.example.com"
export NGINX_CLIENT_MAX_BODY_SIZE="20m"

# HTTPS switch
export ENABLE_HTTPS="true"

# Option A: let the script install certbot and request the cert automatically.
export ENABLE_CERTBOT="true"
export CERTBOT_EMAIL="ops@example.com"
export CERTBOT_DOMAINS="api.example.com"
export CERTBOT_WEBROOT="/var/www/certbot"

# Option B: use existing certificate files instead of certbot auto-issue.
# export ENABLE_CERTBOT="false"
# export SSL_CERT_PATH="/etc/letsencrypt/live/api.example.com/fullchain.pem"
# export SSL_CERT_KEY_PATH="/etc/letsencrypt/live/api.example.com/privkey.pem"
